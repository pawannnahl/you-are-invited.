      padding: 2.5rem 1rem;
      border-bottom: 1px solid #eee4d8;
    }

    .container {
      max-width: 100%;
      margin: 0 auto;
    }

    .section-title {
      font-size: 1.8rem;
      text-align: center;
      margin-bottom: 1.8rem;
      color: #a26e3e;
      font-weight: 500;
      letter-spacing: 1px;
    }

    .section-title:after {
      content: '';
      display: block;
      width: 50px;
      height: 2px;
      background: #c28a5c;
      margin: 10px auto 0;
    }

    /* Events Grid - Mobile Optimized (Single Column) */
