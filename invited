      font-size: 0.85rem;
    }

    /* Info Grid - Mobile */
    .info-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.8rem;
      text-align: center;
    }

    .info-card {
      background: #fefaf4;
      padding: 1rem;
      border-radius: 16px;
    }

    .info-card i {
