    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      font-family: -apple-system, 'Cormorant Garamond', 'Georgia', 'Times New Roman', serif;
      background: #2c2418;
      line-height: 1.5;
      padding: 0;
      margin: 0;
      overflow-x: hidden;
    }

    /* Main Container - Mobile First */
    .invitation {
      max-width: 100%;
      margin: 0 auto;
      background: #fffdf9;
      box-shadow: 0 0 20px rgba(0,0,0,0.1);
    }

    /* Hero Section - Mobile Optimized */
    .hero {
      position: relative;
      background: linear-gradient(rgba(0,0,0,0.35), rgba(0,0,0,0.4)), 
                  url('https://images.pexels.com/photos/572897/pexels-photo-572897.jpeg?auto=compress&cs=tinysrgb&w=800&h=1200&fit=crop');
      background-size: cover;
      background-position: center 30%;
      min-height: 90vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      color: white;
      padding: 1rem;
    }

    /* Decorative Border - Mobile Adjusted */
    .hero-border {
      position: absolute;
      top: 15px;
      left: 15px;
      right: 15px;
      bottom: 15px;
      border: 1px solid rgba(255,235,170,0.55);
      pointer-events: none;
    }

    .hero-content {
      max-width: 100%;
      padding: 1rem;
      position: relative;
      z-index: 2;
    }

    .ganesh-mantra {
      font-size: 0.8rem;
      letter-spacing: 2px;
      background: rgba(0,0,0,0.55);
      display: inline-block;
