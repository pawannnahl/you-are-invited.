      margin-top: 1rem;
      border-top: 1px solid rgba(255,245,200,0.7);
      display: inline-block;
      padding-top: 0.7rem;
    }

    .parents-hero {
      margin-top: 1.2rem;
      font-size: 0.75rem;
      background: rgba(0,0,0,0.5);
      display: inline-block;
      padding: 0.5rem 1.2rem;
      border-radius: 40px;
      backdrop-filter: blur(3px);
      line-height: 1.5;
