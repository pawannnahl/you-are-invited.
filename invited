      letter-spacing: 3px;
      line-height: 1.2;
      text-transform: uppercase;
      text-shadow: 2px 2px 12px rgba(0,0,0,0.6);
      word-break: keep-all;
    }

    .couple-name span {
      font-size: 1.8rem;
      font-weight: 400;
    }

    .wedding-date {
